{%- liquid
  assign options = section.settings
  assign color_scheme = options.color_scheme
  assign container_size = options.container_size
  assign title = options.title
  assign subtitle = options.subtitle
  assign show_breadcrumbs = options.show_breadcrumbs
  assign current_step = options.current_step | default: 1
-%}

<div class="uniforms-hero section-{{ section.id }}">
  {%- if show_breadcrumbs -%}
    <div class="container container--{{ container_size }}">
      <nav class="uniforms-hero__breadcrumbs" role="navigation" aria-label="breadcrumbs">
        <a href="{{ routes.root_url }}">Home</a>
        <span class="breadcrumbs__separator">›</span>
        <span>{{ page.title | default: title }}</span>
      </nav>
    </div>
  {%- endif -%}
  
  <div class="uniforms-hero__background color-{{ color_scheme }}">
    <div class="uniforms-hero__container container container--{{ container_size }}">
      <div class="uniforms-hero__content">
        {%- if title != blank -%}
          <h1 class="uniforms-hero__title">{{ title }}</h1>
        {%- elsif page.title -%}
          <h1 class="uniforms-hero__title">{{ page.title }}</h1>
        {%- endif -%}
        
        {%- if subtitle != blank -%}
          <p class="uniforms-hero__subtitle">{{ subtitle }}</p>
        {%- endif -%}
      </div>
      
      <div class="uniforms-hero__steps uniforms-hero__steps--desktop">
        <div class="step-item {% if current_step >= 1 %}active{% else %}inactive{% endif %}">
          <div class="step-circle-wrapper">
            <svg class="step-number" xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 30 30" fill="none">
              <circle cx="15" cy="15" r="15" fill="{% if current_step >= 1 %}#F74C09{% else %}rgba(255, 255, 255, 0.2){% endif %}"/>
              <text x="15" y="15" text-anchor="middle" dominant-baseline="middle" fill="{% if current_step >= 1 %}white{% else %}rgba(255, 255, 255, 0.5){% endif %}" font-size="14" font-weight="700">1</text>
            </svg>
          </div>
          <div class="step-label">Select category</div>
        </div>
        <div class="step-arrow {% if current_step >= 1 %}active{% endif %}">
          <svg xmlns="http://www.w3.org/2000/svg" width="75" height="6" viewBox="0 0 75 6" fill="none">
            <path d="M75 2.88672L70 -3.26633e-05V5.77347L75 2.88672ZM0 2.88672V3.38672H70.5V2.88672V2.38672H0V2.88672Z" fill="currentColor"/>
          </svg>
        </div>
        <div class="step-item {% if current_step >= 2 %}active{% else %}inactive{% endif %}">
          <div class="step-circle-wrapper">
            <svg class="step-number" xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 30 30" fill="none">
              <circle cx="15" cy="15" r="15" fill="{% if current_step >= 2 %}#F74C09{% else %}rgba(255, 255, 255, 0.2){% endif %}"/>
              <text x="15" y="15" text-anchor="middle" dominant-baseline="middle" fill="{% if current_step >= 2 %}white{% else %}rgba(255, 255, 255, 0.5){% endif %}" font-size="14" font-weight="700">2</text>
            </svg>
          </div>
          <div class="step-label">Select uniform type</div>
        </div>
        <div class="step-arrow {% if current_step >= 2 %}active{% endif %}">
          <svg xmlns="http://www.w3.org/2000/svg" width="75" height="6" viewBox="0 0 75 6" fill="none">
            <path d="M75 2.88672L70 -3.26633e-05V5.77347L75 2.88672ZM0 2.88672V3.38672H70.5V2.88672V2.38672H0V2.88672Z" fill="currentColor"/>
          </svg>
        </div>
        <div class="step-item {% if current_step >= 3 %}active{% else %}inactive{% endif %}">
          <div class="step-circle-wrapper">
            <svg class="step-number" xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 30 30" fill="none">
              <circle cx="15" cy="15" r="15" fill="{% if current_step >= 3 %}#F74C09{% else %}rgba(255, 255, 255, 0.2){% endif %}"/>
              <text x="15" y="15" text-anchor="middle" dominant-baseline="middle" fill="{% if current_step >= 3 %}white{% else %}rgba(255, 255, 255, 0.5){% endif %}" font-size="14" font-weight="700">3</text>
            </svg>
          </div>
          <div class="step-label">Upload designs</div>
        </div>
        <div class="step-arrow {% if current_step >= 3 %}active{% endif %}">
          <svg xmlns="http://www.w3.org/2000/svg" width="75" height="6" viewBox="0 0 75 6" fill="none">
            <path d="M75 2.88672L70 -3.26633e-05V5.77347L75 2.88672ZM0 2.88672V3.38672H70.5V2.88672V2.38672H0V2.88672Z" fill="currentColor"/>
          </svg>
        </div>
        <div class="step-item {% if current_step >= 4 %}active{% else %}inactive{% endif %}">
          <div class="step-circle-wrapper">
            <svg class="step-number" xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 30 30" fill="none">
              <circle cx="15" cy="15" r="15" fill="{% if current_step >= 4 %}#F74C09{% else %}rgba(255, 255, 255, 0.2){% endif %}"/>
              <text x="15" y="15" text-anchor="middle" dominant-baseline="middle" fill="{% if current_step >= 4 %}white{% else %}rgba(255, 255, 255, 0.5){% endif %}" font-size="14" font-weight="700">4</text>
            </svg>
          </div>
          <div class="step-label">Sizes & quantity</div>
        </div>
        <div class="step-arrow {% if current_step >= 4 %}active{% endif %}">
          <svg xmlns="http://www.w3.org/2000/svg" width="75" height="6" viewBox="0 0 75 6" fill="none">
            <path d="M75 2.88672L70 -3.26633e-05V5.77347L75 2.88672ZM0 2.88672V3.38672H70.5V2.88672V2.38672H0V2.88672Z" fill="currentColor"/>
          </svg>
        </div>
        <div class="step-item {% if current_step >= 5 %}active{% else %}inactive{% endif %}">
          <div class="step-circle-wrapper">
            <svg class="step-number" xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 30 30" fill="none">
              <circle cx="15" cy="15" r="15" fill="{% if current_step >= 5 %}#F74C09{% else %}rgba(255, 255, 255, 0.2){% endif %}"/>
              <text x="15" y="15" text-anchor="middle" dominant-baseline="middle" fill="{% if current_step >= 5 %}white{% else %}rgba(255, 255, 255, 0.5){% endif %}" font-size="14" font-weight="700">5</text>
            </svg>
          </div>
          <div class="step-label">Place order</div>
        </div>
      </div>
    </div>
  </div>
  
  {%- liquid
    assign mobile_start = current_step
    if current_step > 3
      assign mobile_start = current_step | minus: 1
    endif
    assign mobile_end = mobile_start | plus: 2
    if mobile_end > 5
      assign mobile_end = 5
      assign mobile_start = 3
    endif
  -%}
  
  <div class="uniforms-hero__steps uniforms-hero__steps--mobile">
    {%- for i in (mobile_start..mobile_end) -%}
      {%- if i == mobile_start and i > 1 -%}
        <div class="step-item {% if current_step >= i %}active{% else %}inactive{% endif %}">
          <div class="step-circle-wrapper">
            <svg class="step-number" xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 30 30" fill="none">
              <circle cx="15" cy="15" r="14.5" fill="{% if current_step >= i %}#F74C09{% else %}white{% endif %}" stroke="{% if current_step >= i %}#F74C09{% else %}#156571{% endif %}"/>
              <text x="15" y="15" text-anchor="middle" dominant-baseline="middle" fill="{% if current_step >= i %}white{% else %}#156571{% endif %}" font-size="14" font-weight="700">{{ i }}</text>
            </svg>
          </div>
          <div class="step-label">
            {%- case i -%}
              {%- when 1 -%}Select category
              {%- when 2 -%}Select uniform type
              {%- when 3 -%}Upload designs
              {%- when 4 -%}Sizes & quantity
              {%- when 5 -%}Place order
            {%- endcase -%}
          </div>
        </div>
        {%- if i < mobile_end -%}
          <div class="step-arrow {% if current_step >= i %}active{% endif %}">
            <svg xmlns="http://www.w3.org/2000/svg" width="75" height="6" viewBox="0 0 75 6" fill="none">
              <path d="M75 2.88672L70 -3.26633e-05V5.77347L75 2.88672ZM0 2.88672V3.38672H70.5V2.88672V2.38672H0V2.88672Z" fill="currentColor"/>
            </svg>
          </div>
        {%- endif -%}
      {%- elsif i == 1 -%}
        <div class="step-item {% if current_step >= 1 %}active{% else %}inactive{% endif %}">
          <div class="step-circle-wrapper">
            <svg class="step-number" xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 30 30" fill="none">
              <circle cx="15" cy="15" r="14.5" fill="{% if current_step >= 1 %}#F74C09{% else %}white{% endif %}" stroke="{% if current_step >= 1 %}#F74C09{% else %}#156571{% endif %}"/>
              <text x="15" y="15" text-anchor="middle" dominant-baseline="middle" fill="{% if current_step >= 1 %}white{% else %}#156571{% endif %}" font-size="14" font-weight="700">1</text>
            </svg>
          </div>
          <div class="step-label">Select category</div>
        </div>
        {%- if 1 < mobile_end -%}
          <div class="step-arrow {% if current_step >= 1 %}active{% endif %}">
            <svg xmlns="http://www.w3.org/2000/svg" width="75" height="6" viewBox="0 0 75 6" fill="none">
              <path d="M75 2.88672L70 -3.26633e-05V5.77347L75 2.88672ZM0 2.88672V3.38672H70.5V2.88672V2.38672H0V2.88672Z" fill="currentColor"/>
            </svg>
          </div>
        {%- endif -%}
      {%- elsif i == 2 -%}
        <div class="step-item {% if current_step >= 2 %}active{% else %}inactive{% endif %}">
          <div class="step-circle-wrapper">
            <svg class="step-number" xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 30 30" fill="none">
              <circle cx="15" cy="15" r="14.5" fill="{% if current_step >= 2 %}#F74C09{% else %}white{% endif %}" stroke="{% if current_step >= 2 %}#F74C09{% else %}#156571{% endif %}"/>
              <text x="15" y="15" text-anchor="middle" dominant-baseline="middle" fill="{% if current_step >= 2 %}white{% else %}#156571{% endif %}" font-size="14" font-weight="700">2</text>
            </svg>
          </div>
          <div class="step-label">Select uniform type</div>
        </div>
        {%- if 2 < mobile_end -%}
          <div class="step-arrow {% if current_step >= 2 %}active{% endif %}">
            <svg xmlns="http://www.w3.org/2000/svg" width="75" height="6" viewBox="0 0 75 6" fill="none">
              <path d="M75 2.88672L70 -3.26633e-05V5.77347L75 2.88672ZM0 2.88672V3.38672H70.5V2.88672V2.38672H0V2.88672Z" fill="currentColor"/>
            </svg>
          </div>
        {%- endif -%}
      {%- elsif i == 3 -%}
        <div class="step-item {% if current_step >= 3 %}active{% else %}inactive{% endif %}">
          <div class="step-circle-wrapper">
            <svg class="step-number" xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 30 30" fill="none">
              <circle cx="15" cy="15" r="14.5" fill="{% if current_step >= 3 %}#F74C09{% else %}white{% endif %}" stroke="{% if current_step >= 3 %}#F74C09{% else %}#156571{% endif %}"/>
              <text x="15" y="15" text-anchor="middle" dominant-baseline="middle" fill="{% if current_step >= 3 %}white{% else %}#156571{% endif %}" font-size="14" font-weight="700">3</text>
            </svg>
          </div>
          <div class="step-label">Upload designs</div>
        </div>
        {%- if 3 < mobile_end -%}
          <div class="step-arrow {% if current_step >= 3 %}active{% endif %}">
            <svg xmlns="http://www.w3.org/2000/svg" width="75" height="6" viewBox="0 0 75 6" fill="none">
              <path d="M75 2.88672L70 -3.26633e-05V5.77347L75 2.88672ZM0 2.88672V3.38672H70.5V2.88672V2.38672H0V2.88672Z" fill="currentColor"/>
            </svg>
          </div>
        {%- endif -%}
      {%- elsif i == 4 -%}
        <div class="step-item {% if current_step >= 4 %}active{% else %}inactive{% endif %}">
          <div class="step-circle-wrapper">
            <svg class="step-number" xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 30 30" fill="none">
              <circle cx="15" cy="15" r="14.5" fill="{% if current_step >= 4 %}#F74C09{% else %}white{% endif %}" stroke="{% if current_step >= 4 %}#F74C09{% else %}#156571{% endif %}"/>
              <text x="15" y="15" text-anchor="middle" dominant-baseline="middle" fill="{% if current_step >= 4 %}white{% else %}#156571{% endif %}" font-size="14" font-weight="700">4</text>
            </svg>
          </div>
          <div class="step-label">Sizes & quantity</div>
        </div>
        {%- if 4 < mobile_end -%}
          <div class="step-arrow {% if current_step >= 4 %}active{% endif %}">
            <svg xmlns="http://www.w3.org/2000/svg" width="75" height="6" viewBox="0 0 75 6" fill="none">
              <path d="M75 2.88672L70 -3.26633e-05V5.77347L75 2.88672ZM0 2.88672V3.38672H70.5V2.88672V2.38672H0V2.88672Z" fill="currentColor"/>
            </svg>
          </div>
        {%- endif -%}
      {%- elsif i == 5 -%}
        <div class="step-item {% if current_step >= 5 %}active{% else %}inactive{% endif %}">
          <div class="step-circle-wrapper">
            <svg class="step-number" xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 30 30" fill="none">
              <circle cx="15" cy="15" r="14.5" fill="{% if current_step >= 5 %}#F74C09{% else %}white{% endif %}" stroke="{% if current_step >= 5 %}#F74C09{% else %}#156571{% endif %}"/>
              <text x="15" y="15" text-anchor="middle" dominant-baseline="middle" fill="{% if current_step >= 5 %}white{% else %}#156571{% endif %}" font-size="14" font-weight="700">5</text>
            </svg>
          </div>
          <div class="step-label">Place order</div>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

<style>
  .uniforms-hero {
    padding: 0;
    border-top: 1px solid #EDEDED;
  }

  .uniforms-hero__background {
    width: 100%;
    background: linear-gradient(115deg, #156571 50%, #0C4149 50%);
    color: var(--gsc-text-color-100);
  }

  .uniforms-hero__container {
    margin: 0 auto;
    padding: 3rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 3rem;
  }

  .uniforms-hero__breadcrumbs {
    padding: 1.5rem 2rem 0.5rem;
    font-size: 1rem;
    color: #1A1A1A;
  }

  .uniforms-hero__breadcrumbs a {
    color: #1A1A1A;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .uniforms-hero__breadcrumbs a:hover {
    color: #333;
  }

  .breadcrumbs__separator {
    margin: 0 0.5rem;
  }

  .uniforms-hero__content {
    max-width: 800px;
  }

  .uniforms-hero__title {
    font-size: 3rem;
    font-weight: 700;
    margin: 0 0 0.5rem 0;
    line-height: 1.2;
    color: var(--gsc-text-color-100);
  }

  .uniforms-hero__subtitle {
    margin: 0;
    color: var(--gsc-text-color-100);
    opacity: 0.9;
  }

  .uniforms-hero__steps {
    display: flex;
    align-items: flex-start;
    gap: 0;
    flex-shrink: 0;
  }

  .step-item {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    position: relative;
  }

  .step-circle-wrapper {
    display: block;
    line-height: 0;
    font-size: 0;
  }

  .step-number {
    display: block;
    vertical-align: top;
  }

  .step-label {
    font-size: 1.1rem;
    color: rgba(255, 255, 255, 0.5);
    text-align: left;
    white-space: nowrap;
    font-weight: 500;
    margin-top: 0.5rem;
    position: absolute;
    top: 35px;
    left: 0;
  }

  .step-item.active .step-label {
    color: #FF6B35;
  }

  .step-arrow {
    color: rgba(255, 255, 255, 0.3);
    margin: 0 1rem 0 0;
    padding: 0;
    display: inline-block;
    line-height: 0;
    vertical-align: top;
    margin-top: 12px;
  }

  .step-arrow.active {
    color: #FF6B35;
  }

  .step-arrow svg {
    display: block;
  }

  .uniforms-hero__steps--mobile {
    display: none;
  }

  @media (max-width: 768px) {
    .uniforms-hero {
      padding: 0;
    }

    .uniforms-hero__breadcrumbs {
      padding: 1rem 1.5rem 0.5rem;
    }

    .uniforms-hero__background {
      background: #156571;
    }

    .uniforms-hero__container {
      flex-direction: column;
      gap: 0;
      padding: 2rem 1.5rem;
      align-items: flex-start;
    }

    .uniforms-hero__content {
      text-align: left;
    }

    .uniforms-hero__title {
      font-size: 1.75rem;
      text-align: left;
    }

    .uniforms-hero__subtitle {
      text-align: left;
    }

    .uniforms-hero__steps--desktop {
      display: none;
    }

    .uniforms-hero__steps--mobile {
      display: flex;
      justify-content: center;
      align-items: flex-start;
      gap: 0;
      padding: 2rem 1.5rem;
      background: transparent;
    }

    .uniforms-hero__steps--mobile .step-item.inactive .step-label {
      color: #156571;
    }

    .uniforms-hero__steps--mobile .step-arrow {
      color: #156571;
      margin: 1rem 3rem 0 0;
    }

    .uniforms-hero__steps--mobile .step-arrow.active {
      color: #FF6B35;
    }
  }
</style>

{% schema %}
{
  "name": "Uniforms Hero",
  "settings": [
    {
      "type": "select",
      "id": "color_scheme",
      "options": [
        {
          "value": "default",
          "label": "t:sections.general_section_settings.color_scheme_option_default_label"
        },
        {
          "value": "primary",
          "label": "t:sections.general_section_settings.color_scheme_option_primary_label"
        },
        {
          "value": "secondary",
          "label": "t:sections.general_section_settings.color_scheme_option_secondary_label"
        },
        {
          "value": "custom-1",
          "label": "t:sections.general_section_settings.color_scheme_option_custom_1_label"
        },
        {
          "value": "custom-2",
          "label": "t:sections.general_section_settings.color_scheme_option_custom_2_label"
        },
        {
          "value": "custom-3",
          "label": "t:sections.general_section_settings.color_scheme_option_custom_3_label"
        }
      ],
      "default": "default",
      "label": "t:sections.general_section_settings.color_scheme_label",
      "info": "t:sections.general_section_settings.color_scheme_tip"
    },
    {
      "type": "select",
      "id": "container_size",
      "options": [
        {
          "value": "full-screen",
          "label": "t:sections.general_section_settings.container_size.screen_width_option"
        },
        {
          "value": "page-width",
          "label": "t:sections.general_section_settings.container_size.page_width_option"
        },
        {
          "value": "large",
          "label": "t:sections.general_section_settings.container_size.large_width_option"
        },
        {
          "value": "medium",
          "label": "t:sections.general_section_settings.container_size.medium_width_option"
        }
      ],
      "default": "page-width",
      "label": "t:sections.general_section_settings.container_size.label"
    },
    {
      "type": "text",
      "id": "title",
      "default": "Shop All Uniforms",
      "label": "Title"
    },
    {
      "type": "text",
      "id": "subtitle",
      "default": "5-8 weeks turn around time",
      "label": "Subtitle"
    },
    {
      "type": "checkbox",
      "id": "show_breadcrumbs",
      "default": true,
      "label": "Show breadcrumbs"
    },
    {
      "type": "range",
      "id": "current_step",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 1,
      "label": "Current Step",
      "info": "Select which step is currently active (1-5)"
    }
  ],
  "presets": [
    {
      "name": "Uniforms Hero"
    }
  ]
}
{% endschema %}
