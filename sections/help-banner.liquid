{%- liquid
  assign options = section.settings
  assign color_scheme = options.color_scheme
  assign container_size = options.container_size
  assign heading = options.heading
  assign subtext = options.subtext
  assign phone_text = options.phone_text
  assign phone_number = options.phone_number
  assign email_text = options.email_text
  assign email_address = options.email_address
  assign section_spacing_top = options.section_spacing_top
  assign section_spacing_bottom = options.section_spacing_bottom
  assign heading_size = options.heading_size
  assign body_size = options.body_size
-%}

{% capture css %}
  {% style %}
    .section-{{ section.id }} {
      --gsc-section-spacing-top: {{ section_spacing_top }}px;
      --gsc-section-spacing-bottom: {{ section_spacing_bottom }}px;
    }

    @media only screen and (min-width:768px) and (max-width:1199px) {
      .section-{{ section.id }} {
        --gsc-section-spacing-top: {{ section_spacing_top | times: 0.50 }}px;
        --gsc-section-spacing-bottom: {{ section_spacing_bottom | times: 0.50 }}px;
      }
    }

    @media only screen and (max-width:767px) {
      .section-{{ section.id }} {
        --gsc-section-spacing-top: {{ section_spacing_top | times: 0.75 }}px;
        --gsc-section-spacing-bottom: {{ section_spacing_bottom | times: 0.75 }}px;
      }
    }
  {% endstyle %}
{% endcapture %}

{% render 'inline-css-minifier', css: css %}

<div class="help-banner section section-{{ section.id }} color-{{ color_scheme }}">
  <div class="help-banner__container container container--{{ container_size }} section-spacing">
    <div class="help-banner__content">
      {%- if heading != blank -%}
        <h2 class="help-banner__heading {{ heading_size }}">{{ heading }}</h2>
      {%- endif -%}
      
      {%- if subtext != blank -%}
        <div class="help-banner__subtext {{ body_size }} body-font-weight-from-global-settings">
          {{ subtext }}
        </div>
      {%- endif -%}
      
      <div class="help-banner__contact">
        {%- if phone_text != blank and phone_number != blank -%}
          <p class="help-banner__contact-item {{ body_size }}">
            {{ phone_text }} <a href="tel:{{ phone_number | replace: ' ', '' | replace: '(', '' | replace: ')', '' }}" class="help-banner__link">{{ phone_number }}</a> and we'll help you get sorted.
          </p>
        {%- endif -%}
        
        {%- if email_text != blank and email_address != blank -%}
          <p class="help-banner__contact-item {{ body_size }}">
            <b>Prefer email?</b> Reach us <a href="mailto:{{ email_address }}" class="help-banner__link">{{ email_address }}</a>
          </p>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

<style>
  .help-banner {
    width: 100%;
  }

  .help-banner__container {
    margin: 0 auto;
  }

  .help-banner__content {
    text-align: center;
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .help-banner__heading {
    margin: 0 0 1rem 0;
    font-weight: 700;
    line-height: 1.2;
  }

  .help-banner__subtext {
    margin: 0 0 1.5rem 0;
    line-height: 1.5;
    color: #222222;
  }

  .help-banner__contact {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    color: #222222;
  }

  .help-banner__contact-item {
    margin: 0;
    line-height: 1.6;
  }

  .help-banner__link {
    color: var(--GREEN, #156571);
    text-decoration: underline;
    font-weight: 600;
    transition: opacity 0.2s ease;
  }

  .help-banner__link:hover {
    opacity: 0.7;
  }

  /* Mobile Styles */
  @media (max-width: 767px) {
    .help-banner__content {
      padding: 1.5rem 1rem;
    }

    .help-banner__heading {
      font-size: 1.5rem;
    }

    .help-banner__contact {
      gap: 0.75rem;
    }
  }
</style>

{% schema %}
{
  "name": "Help Banner",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Section Settings"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "options": [
        {
          "value": "default",
          "label": "t:sections.general_section_settings.color_scheme_option_default_label"
        },
        {
          "value": "primary",
          "label": "t:sections.general_section_settings.color_scheme_option_primary_label"
        },
        {
          "value": "secondary",
          "label": "t:sections.general_section_settings.color_scheme_option_secondary_label"
        },
        {
          "value": "custom-1",
          "label": "t:sections.general_section_settings.color_scheme_option_custom_1_label"
        },
        {
          "value": "custom-2",
          "label": "t:sections.general_section_settings.color_scheme_option_custom_2_label"
        },
        {
          "value": "custom-3",
          "label": "t:sections.general_section_settings.color_scheme_option_custom_3_label"
        }
      ],
      "default": "custom-1",
      "label": "t:sections.general_section_settings.color_scheme_label",
      "info": "t:sections.general_section_settings.color_scheme_tip"
    },
    {
      "type": "select",
      "id": "container_size",
      "options": [
        {
          "value": "full-screen",
          "label": "t:sections.general_section_settings.container_size.screen_width_option"
        },
        {
          "value": "page-width",
          "label": "t:sections.general_section_settings.container_size.page_width_option"
        },
        {
          "value": "large",
          "label": "t:sections.general_section_settings.container_size.large_width_option"
        },
        {
          "value": "medium",
          "label": "t:sections.general_section_settings.container_size.medium_width_option"
        }
      ],
      "default": "page-width",
      "label": "t:sections.general_section_settings.container_size.label"
    },
    {
      "type": "range",
      "id": "section_spacing_top",
      "min": 0,
      "max": 200,
      "step": 10,
      "default": 60,
      "unit": "px",
      "label": "Section Spacing Top"
    },
    {
      "type": "range",
      "id": "section_spacing_bottom",
      "min": 0,
      "max": 200,
      "step": 10,
      "default": 60,
      "unit": "px",
      "label": "Section Spacing Bottom"
    },
    {
      "type": "header",
      "content": "Content Settings"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Need Help Ordering or Need It by a Certain Date?"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h1",
          "label": "Heading 1"
        },
        {
          "value": "h2",
          "label": "Heading 2"
        },
        {
          "value": "h3",
          "label": "Heading 3"
        },
        {
          "value": "h4",
          "label": "Heading 4"
        },
        {
          "value": "h5",
          "label": "Heading 5"
        },
        {
          "value": "h6",
          "label": "Heading 6"
        }
      ],
      "default": "h2",
      "label": "Heading Size"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "We're here to make it easy. Whether you're unsure how to place your order or need products quickly."
    },
    {
      "type": "select",
      "id": "body_size",
      "options": [
        {
          "value": "body-sm",
          "label": "Small"
        },
        {
          "value": "body-md",
          "label": "Medium"
        },
        {
          "value": "body-lg",
          "label": "Large"
        }
      ],
      "default": "body-md",
      "label": "Body Text Size"
    },
    {
      "type": "header",
      "content": "Phone Settings"
    },
    {
      "type": "text",
      "id": "phone_text",
      "label": "Phone Text",
      "default": "Call us on"
    },
    {
      "type": "text",
      "id": "phone_number",
      "label": "Phone Number",
      "default": "(07) 2103 3604"
    },
    {
      "type": "header",
      "content": "Email Settings"
    },
    {
      "type": "text",
      "id": "email_text",
      "label": "Email Text",
      "default": "Prefer email? Reach us at"
    },
    {
      "type": "text",
      "id": "email_address",
      "label": "Email Address",
      "default": "corporate@yarn.com.au"
    }
  ],
  "presets": [
    {
      "name": "Help Banner",
      "settings": {
        "heading": "Need Help Ordering or Need It by a Certain Date?",
        "subtext": "We're here to make it easy. Whether you're unsure how to place your order or need products quickly.",
        "phone_text": "Call us on",
        "phone_number": "(07) 2103 3604",
        "email_text": "Prefer email? Reach us at",
        "email_address": "corporate@yarn.com.au"
      }
    }
  ]
}
{% endschema %}
