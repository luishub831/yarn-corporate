{%- liquid
  assign options = section.settings
  assign heading = options.heading
  assign container_size = options.container_size
-%}

<div class="uniforms-collection-grid section-{{ section.id }}">
  <div class="container container--{{ container_size }}">
    <div class="collection-filters">
      <button class="filter-btn active" data-collection="all">ALL</button>
      {%- for block in section.blocks -%}
        {%- if block.type == 'collection' -%}
          <button class="filter-btn" data-collection="{{ block.settings.collection }}">
            {{ block.settings.button_label }}
          </button>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="products-grid" id="products-grid-{{ section.id }}">
      <div class="products-loading">Loading...</div>
    </div>
  </div>
</div>

<style>
  .uniforms-collection-grid {
    padding: 3rem 0;
  }

  .collection-filters {
    display: flex;
    justify-content: flex-end;
    gap: 1rem;
    margin-bottom: 3rem;
    flex-wrap: wrap;
  }

  .filter-btn {
    padding: 0.75rem 1.5rem;
    background: white;
    border: 1px solid #000;
    color: #000;
    font-size: 1.2rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.3s ease;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.36px;
  }

  .filter-btn:hover,
  .filter-btn.active {
    background: #000;
    color: white;
    border-color: #000;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    margin-top: 2rem;
  }

  .products-loading {
    grid-column: 1 / -1;
    text-align: center;
    padding: 3rem;
    color: #666;
  }

  .product-card {
    position: relative;
    background: #f5f5f5;
    border-radius: 8px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .product-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
  }

  .product-image-wrapper {
    position: relative;
    padding-top: 100%;
    overflow: hidden;
    background: #f5f5f5;
    border-radius: 8px;
  }

  .product-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product-hover-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(21, 101, 113, 0.7);
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding-bottom: 2rem;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .product-card:hover .product-hover-overlay {
    opacity: 1;
  }

  .customize-btn {
    background: #FF6B35;
    color: white;
    border: none;
    padding: 1rem 2rem;
    font-size: 1.25rem;
    font-weight: 700;
    text-transform: uppercase;
    border-radius: 50px;
    cursor: pointer;
    transition: background 0.3s ease;
    text-decoration: none;
    display: inline-block;
  }

  .customize-btn:hover {
    background: #F74C09;
  }

  .product-info {
    padding: 1.5rem;
    background: white;
  }

  .product-title {
    font-size: 1.8rem;
    font-weight: 600;
    margin: 0 0 0.75rem 0;
    color: #1A1A1A;
    line-height: 1.4;
  }

  .product-price-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }

  .product-price {
    font-size: 1.6rem;
    font-weight: 700;
    color: #106572;
    border: 1px solid #106572;
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
  }

  .product-min-qty {
    font-size: 1.6rem;
    color: #156571;
    font-weight: 700;
  }

  .product-production-time {
    font-size: 1.4rem;
    color: #444;
    font-weight: 400;
  }

  @media (max-width: 1024px) {
    .products-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }
  }

  @media (max-width: 768px) {
    .products-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }

    .collection-filters {
      gap: 0.5rem;
      margin-bottom: 2rem;
    }

    .filter-btn {
      padding: 0.5rem 1rem;
      font-size: 0.75rem;
    }

    .product-info {
      padding: 1rem;
    }

    .product-title {
      font-size: 0.875rem;
    }

    .customize-btn {
      padding: 0.75rem 1.5rem;
      font-size: 0.75rem;
    }
  }
</style>

<script>
  (function() {
    const sectionId = '{{ section.id }}';
    const productsGrid = document.getElementById('products-grid-' + sectionId);
    const filterBtns = document.querySelectorAll('.uniforms-collection-grid .filter-btn');
    
    const collections = {
      {%- for block in section.blocks -%}
        {%- if block.type == 'collection' -%}
          '{{ block.settings.collection }}': '{{ block.settings.collection }}',
        {%- endif -%}
      {%- endfor -%}
    };

    async function loadProducts(collectionHandle) {
      productsGrid.innerHTML = '<div class="products-loading">Loading...</div>';
      
      try {
        let products = [];
        
        if (collectionHandle === 'all') {
          // Load products from all collections
          for (const handle of Object.values(collections)) {
            const response = await fetch(`/collections/${handle}/products.json`);
            const data = await response.json();
            products = products.concat(data.products);
          }
        } else {
          // Load products from specific collection
          const response = await fetch(`/collections/${collectionHandle}/products.json`);
          const data = await response.json();
          products = data.products;
        }
        
        renderProducts(products);
      } catch (error) {
        console.error('Error loading products:', error);
        productsGrid.innerHTML = '<div class="products-loading">Error loading products</div>';
      }
    }

    function renderProducts(products) {
      if (!products || products.length === 0) {
        productsGrid.innerHTML = '<div class="products-loading">No products found</div>';
        return;
      }

      const productsHTML = products.map(product => {
        // Get price from metafields or default to variant price
        let priceDisplay = '';
        const newPricing = product.metafields && product.metafields.custom && product.metafields.custom.new_pricing ? 
          product.metafields.custom.new_pricing : null;
        
        if (newPricing) {
          priceDisplay = newPricing;
        } else {
          const price = product.variants && product.variants[0] ? 
            parseFloat(product.variants[0].price).toFixed(2) : '0.00';
          priceDisplay = '$' + price;
        }
        
        const image = product.images && product.images[0] ? 
          (typeof product.images[0] === 'string' ? product.images[0] : product.images[0].src) : '';
        
        // Get min qty from metafields or default to 15
        const minQty = product.metafields && product.metafields.custom && product.metafields.custom.min_qty ? 
          product.metafields.custom.min_qty : 15;
        
        // Get production time from metafields or default to '5-6 weeks'
        const productionTime = product.metafields && product.metafields.custom && product.metafields.custom.production_time ? 
          product.metafields.custom.production_time : '5-6 weeks';
        
        return `
          <div class="product-card">
            <div class="product-image-wrapper">
              <img src="${image}" alt="${product.title}" class="product-image" loading="lazy">
              <div class="product-hover-overlay">
                <a href="/products/${product.handle}" class="customize-btn">START CUSTOMIZING</a>
              </div>
            </div>
            <div class="product-info">
              <h3 class="product-title">Design Your Own: ${product.title}</h3>
              <div class="product-price-row">
                <span class="product-price">From ${priceDisplay}</span>
                <span class="product-min-qty">Min Qty: ${minQty}</span>
              </div>
              <div class="product-production-time">Production Time: <b>${productionTime}</b></div>
            </div>
          </div>
        `;
      }).join('');

      productsGrid.innerHTML = productsHTML;
    }

    // Filter button click handlers
    filterBtns.forEach(btn => {
      btn.addEventListener('click', function() {
        // Update active state
        filterBtns.forEach(b => b.classList.remove('active'));
        this.classList.add('active');
        
        // Load products
        const collectionHandle = this.dataset.collection;
        loadProducts(collectionHandle);
      });
    });

    // Load all products initially
    loadProducts('all');
  })();
</script>

{% schema %}
{
  "name": "Uniforms Collection Grid",
  "settings": [
    {
      "type": "select",
      "id": "container_size",
      "options": [
        {
          "value": "full-screen",
          "label": "Full Screen"
        },
        {
          "value": "page-width",
          "label": "Page Width"
        },
        {
          "value": "large",
          "label": "Large"
        },
        {
          "value": "medium",
          "label": "Medium"
        }
      ],
      "default": "page-width",
      "label": "Container Size"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection Filter",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button Label",
          "default": "CATEGORY"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Uniforms Collection Grid",
      "blocks": [
        {
          "type": "collection",
          "settings": {
            "button_label": "POLOS"
          }
        },
        {
          "type": "collection",
          "settings": {
            "button_label": "SHIRTS"
          }
        },
        {
          "type": "collection",
          "settings": {
            "button_label": "SCRUBS"
          }
        },
        {
          "type": "collection",
          "settings": {
            "button_label": "BLOUSE"
          }
        },
        {
          "type": "collection",
          "settings": {
            "button_label": "ACCESSORIES"
          }
        }
      ]
    }
  ]
}
{% endschema %}
