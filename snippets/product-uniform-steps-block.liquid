{%- liquid
  assign options = block.settings
  assign current_step = options.current_step | default: 3
-%}

<div class='product-uniform-steps-block block-{{ block.id }}' {{ block.shopify_attributes }}>
  <div class="uniforms-hero__steps uniforms-hero__steps--desktop">
    <div class="step-item {% if current_step > 1 %}passed{% elsif current_step == 1 %}active{% else %}inactive{% endif %}">
      <div class="step-circle-wrapper">
        <svg class="step-number" xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 30 30" fill="none">
          {% if current_step > 1 %}
            <circle cx="15" cy="15" r="14.5" fill="transparent" stroke="#F74C09"/>
            <path d="M9 15l4 4 8-8" stroke="#F74C09" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
          {% elsif current_step == 1 %}
            <circle cx="15" cy="15" r="15" fill="#F74C09"/>
            <text x="15" y="15" text-anchor="middle" dominant-baseline="middle" fill="white" font-size="14" font-weight="400">1</text>
          {% else %}
            <circle cx="15" cy="15" r="14.5" fill="transparent" stroke="#CCCCCC" stroke-width="2"/>
            <text x="15" y="15" text-anchor="middle" dominant-baseline="middle" fill="#999999" font-size="14" font-weight="400">1</text>
          {% endif %}
        </svg>
      </div>
      <div class="step-label">Select category</div>
    </div>
    <div class="step-arrow {% if current_step >= 1 %}active{% endif %}">
      <svg xmlns="http://www.w3.org/2000/svg" width="75" height="6" viewBox="0 0 75 6" fill="none">
        <path d="M75 2.88672L70 -3.26633e-05V5.77347L75 2.88672ZM0 2.88672V3.38672H70.5V2.88672V2.38672H0V2.88672Z" fill="currentColor"/>
      </svg>
    </div>
    <div class="step-item {% if current_step > 2 %}passed{% elsif current_step == 2 %}active{% else %}inactive{% endif %}">
      <div class="step-circle-wrapper">
        <svg class="step-number" xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 30 30" fill="none">
          {% if current_step > 2 %}
            <circle cx="15" cy="15" r="14.5" fill="transparent" stroke="#F74C09"/>
            <path d="M9 15l4 4 8-8" stroke="#F74C09" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
          {% elsif current_step == 2 %}
            <circle cx="15" cy="15" r="15" fill="#F74C09"/>
            <text x="15" y="15" text-anchor="middle" dominant-baseline="middle" fill="white" font-size="14" font-weight="400">2</text>
          {% else %}
            <circle cx="15" cy="15" r="14.5" fill="transparent" stroke="#CCCCCC" stroke-width="2"/>
            <text x="15" y="15" text-anchor="middle" dominant-baseline="middle" fill="#999999" font-size="14" font-weight="400">2</text>
          {% endif %}
        </svg>
      </div>
      <div class="step-label">Select uniform type</div>
    </div>
    <div class="step-arrow {% if current_step >= 2 %}active{% endif %}">
      <svg xmlns="http://www.w3.org/2000/svg" width="75" height="6" viewBox="0 0 75 6" fill="none">
        <path d="M75 2.88672L70 -3.26633e-05V5.77347L75 2.88672ZM0 2.88672V3.38672H70.5V2.88672V2.38672H0V2.88672Z" fill="currentColor"/>
      </svg>
    </div>
    <div class="step-item {% if current_step > 3 %}passed{% elsif current_step == 3 %}active{% else %}inactive{% endif %}">
      <div class="step-circle-wrapper">
        <svg class="step-number" xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 30 30" fill="none">
          {% if current_step > 3 %}
            <circle cx="15" cy="15" r="14.5" fill="transparent" stroke="#F74C09"/>
            <path d="M9 15l4 4 8-8" stroke="#F74C09" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
          {% elsif current_step == 3 %}
            <circle cx="15" cy="15" r="15" fill="#F74C09"/>
            <text x="15" y="15" text-anchor="middle" dominant-baseline="middle" fill="white" font-size="14" font-weight="400">3</text>
          {% else %}
            <circle cx="15" cy="15" r="14.5" fill="transparent" stroke="#CCCCCC" stroke-width="2"/>
            <text x="15" y="15" text-anchor="middle" dominant-baseline="middle" fill="#999999" font-size="14" font-weight="400">3</text>
          {% endif %}
        </svg>
      </div>
      <div class="step-label">Upload designs</div>
    </div>
    <div class="step-arrow {% if current_step >= 3 %}active{% endif %}">
      <svg xmlns="http://www.w3.org/2000/svg" width="75" height="6" viewBox="0 0 75 6" fill="none">
        <path d="M75 2.88672L70 -3.26633e-05V5.77347L75 2.88672ZM0 2.88672V3.38672H70.5V2.88672V2.38672H0V2.88672Z" fill="currentColor"/>
      </svg>
    </div>
    <div class="step-item {% if current_step > 4 %}passed{% elsif current_step == 4 %}active{% else %}inactive{% endif %}">
      <div class="step-circle-wrapper">
        <svg class="step-number" xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 30 30" fill="none">
          {% if current_step > 4 %}
            <circle cx="15" cy="15" r="14.5" fill="transparent" stroke="#F74C09"/>
            <path d="M9 15l4 4 8-8" stroke="#F74C09" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
          {% elsif current_step == 4 %}
            <circle cx="15" cy="15" r="15" fill="#F74C09"/>
            <text x="15" y="15" text-anchor="middle" dominant-baseline="middle" fill="white" font-size="14" font-weight="400">4</text>
          {% else %}
            <circle cx="15" cy="15" r="14.5" fill="transparent" stroke="#CCCCCC" stroke-width="2"/>
            <text x="15" y="15" text-anchor="middle" dominant-baseline="middle" fill="#999999" font-size="14" font-weight="400">4</text>
          {% endif %}
        </svg>
      </div>
      <div class="step-label">Sizes & quantity</div>
    </div>
    <div class="step-arrow {% if current_step >= 4 %}active{% endif %}">
      <svg xmlns="http://www.w3.org/2000/svg" width="75" height="6" viewBox="0 0 75 6" fill="none">
        <path d="M75 2.88672L70 -3.26633e-05V5.77347L75 2.88672ZM0 2.88672V3.38672H70.5V2.88672V2.38672H0V2.88672Z" fill="currentColor"/>
      </svg>
    </div>
    <div class="step-item {% if current_step == 5 %}active{% else %}inactive{% endif %}">
      <div class="step-circle-wrapper">
        <svg class="step-number" xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 30 30" fill="none">
          {% if current_step == 5 %}
            <circle cx="15" cy="15" r="15" fill="#F74C09"/>
            <text x="15" y="15" text-anchor="middle" dominant-baseline="middle" fill="white" font-size="14" font-weight="400">5</text>
          {% else %}
            <circle cx="15" cy="15" r="14.5" fill="transparent" stroke="#CCCCCC" stroke-width="2"/>
            <text x="15" y="15" text-anchor="middle" dominant-baseline="middle" fill="#999999" font-size="14" font-weight="400">5</text>
          {% endif %}
        </svg>
      </div>
      <div class="step-label">Place order</div>
    </div>
  </div>
  
  {%- liquid
    assign mobile_start = current_step
    if current_step > 3
      assign mobile_start = current_step | minus: 1
    endif
    assign mobile_end = mobile_start | plus: 2
    if mobile_end > 5
      assign mobile_end = 5
      assign mobile_start = 3
    endif
  -%}
  
  <div class="uniforms-hero__steps uniforms-hero__steps--mobile">
    {%- for i in (mobile_start..mobile_end) -%}
      <div class="step-item {% if current_step >= i %}active{% else %}inactive{% endif %}">
        <div class="step-circle-wrapper">
          <svg class="step-number" xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 30 30" fill="none">
            <circle cx="15" cy="15" r="14.5" fill="{% if current_step >= i %}#F74C09{% else %}white{% endif %}" stroke="{% if current_step >= i %}#F74C09{% else %}#999999{% endif %}"/>
            <text x="15" y="15" text-anchor="middle" dominant-baseline="middle" fill="{% if current_step >= i %}white{% else %}#999999{% endif %}" font-size="14" font-weight="400">{{ i }}</text>
          </svg>
        </div>
        <div class="step-label">
          {%- case i -%}
            {%- when 1 -%}Select category
            {%- when 2 -%}Select uniform type
            {%- when 3 -%}Upload designs
            {%- when 4 -%}Sizes & quantity
            {%- when 5 -%}Place order
          {%- endcase -%}
        </div>
      </div>
      {%- if i < mobile_end -%}
        <div class="step-arrow {% if current_step >= i %}active{% endif %}">
          <svg xmlns="http://www.w3.org/2000/svg" width="75" height="6" viewBox="0 0 75 6" fill="none">
            <path d="M75 2.88672L70 -3.26633e-05V5.77347L75 2.88672ZM0 2.88672V3.38672H70.5V2.88672V2.38672H0V2.88672Z" fill="currentColor"/>
          </svg>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
  
  <div class="product-upload" data-step-content="3">
    {% render 'upload' %}
    <div class="uniform-step-navigation">
      <button type="button" class="uniform-nav-btn uniform-nav-btn--back" onclick="goToStep(2)">
        <svg xmlns="http://www.w3.org/2000/svg" width="12" height="8" viewBox="0 0 12 8" fill="none">
          <path d="M10.5215 4.18201C10.7976 4.18201 11.0215 3.95815 11.0215 3.68201C11.0215 3.40586 10.7976 3.18201 10.5215 3.18201V3.68201V4.18201ZM0.14712 3.32845C-0.0481434 3.52372 -0.0481434 3.8403 0.14712 4.03556L3.3291 7.21754C3.52436 7.4128 3.84094 7.4128 4.03621 7.21754C4.23147 7.02228 4.23147 6.7057 4.03621 6.51043L1.20778 3.68201L4.03621 0.85358C4.23147 0.658318 4.23147 0.341735 4.03621 0.146473C3.84094 -0.0487893 3.52436 -0.0487893 3.3291 0.146473L0.14712 3.32845ZM10.5215 3.68201V3.18201L0.500672 3.18201V3.68201V4.18201L10.5215 4.18201V3.68201Z" fill="currentColor"/>
        </svg>
        BACK
      </button>
      <button type="button" class="uniform-nav-btn uniform-nav-btn--next" onclick="goToStep(4)">
        NEXT STEP
        <svg xmlns="http://www.w3.org/2000/svg" width="12" height="8" viewBox="0 0 12 8" fill="none">
          <path d="M1.47852 3.81799C1.20238 3.81799 0.978516 4.04185 0.978516 4.31799C0.978516 4.59414 1.20238 4.81799 1.47852 4.81799V3.81799V3.81799ZM11.8529 4.67155C12.0482 4.47628 12.0482 4.1597 11.8529 3.96444L8.6709 0.782458C8.47564 0.587196 8.15906 0.587196 7.96379 0.782458C7.76853 0.977721 7.76853 1.2943 7.96379 1.48956L10.7922 4.31799L7.96379 7.14642C7.76853 7.34168 7.76853 7.65827 7.96379 7.85353C8.15906 8.04879 8.47564 8.04879 8.6709 7.85353L11.8529 4.67155ZM1.47852 4.81799H11.4993V3.81799V3.81799H1.47852V4.81799Z" fill="currentColor"/>
        </svg>
      </button>
    </div>
  </div>
  <div class="product-form-step" data-step-content="4" style="display: none;">
    {% render 'product-form-block-uniform', product: product, section: section, block: block, sectionId: sectionId %}
    <div class="uniform-step-navigation">
      <button type="button" class="uniform-nav-btn uniform-nav-btn--back" onclick="goToStep(3)">
        <svg xmlns="http://www.w3.org/2000/svg" width="12" height="8" viewBox="0 0 12 8" fill="none">
          <path d="M10.5215 4.18201C10.7976 4.18201 11.0215 3.95815 11.0215 3.68201C11.0215 3.40586 10.7976 3.18201 10.5215 3.18201V3.68201V4.18201ZM0.14712 3.32845C-0.0481434 3.52372 -0.0481434 3.8403 0.14712 4.03556L3.3291 7.21754C3.52436 7.4128 3.84094 7.4128 4.03621 7.21754C4.23147 7.02228 4.23147 6.7057 4.03621 6.51043L1.20778 3.68201L4.03621 0.85358C4.23147 0.658318 4.23147 0.341735 4.03621 0.146473C3.84094 -0.0487893 3.52436 -0.0487893 3.3291 0.146473L0.14712 3.32845ZM10.5215 3.68201V3.18201L0.500672 3.18201V3.68201V4.18201L10.5215 4.18201V3.68201Z" fill="currentColor"/>
        </svg>
        BACK
      </button>
      <button type="button" class="uniform-nav-btn uniform-nav-btn--next" onclick="goToStep(5)">
        NEXT STEP
        <svg xmlns="http://www.w3.org/2000/svg" width="12" height="8" viewBox="0 0 12 8" fill="none">
          <path d="M1.47852 3.81799C1.20238 3.81799 0.978516 4.04185 0.978516 4.31799C0.978516 4.59414 1.20238 4.81799 1.47852 4.81799V3.81799V3.81799ZM11.8529 4.67155C12.0482 4.47628 12.0482 4.1597 11.8529 3.96444L8.6709 0.782458C8.47564 0.587196 8.15906 0.587196 7.96379 0.782458C7.76853 0.977721 7.76853 1.2943 7.96379 1.48956L10.7922 4.31799L7.96379 7.14642C7.76853 7.34168 7.76853 7.65827 7.96379 7.85353C8.15906 8.04879 8.47564 8.04879 8.6709 7.85353L11.8529 4.67155ZM1.47852 4.81799H11.4993V3.81799V3.81799H1.47852V4.81799Z" fill="currentColor"/>
        </svg>
      </button>
    </div>
  </div>
</div>

<script>
  function goToStep(stepNumber) {
    // Update the uniform steps visual
    const stepsBlock = document.querySelector('.product-uniform-steps-block');
    if (!stepsBlock) return;
    
    // Update DESKTOP step classes and SVG content
    const desktopSteps = stepsBlock.querySelector('.uniforms-hero__steps--desktop');
    if (desktopSteps) {
      const stepItems = desktopSteps.querySelectorAll('.step-item');
      stepItems.forEach((item, index) => {
        const step = index + 1;
        item.classList.remove('active', 'passed', 'inactive');
        
        const svg = item.querySelector('.step-number');
        
        if (step < stepNumber) {
          item.classList.add('passed');
          // Show checkmark for passed steps
          svg.innerHTML = `
            <circle cx="15" cy="15" r="14.5" fill="transparent" stroke="#F74C09"/>
            <path d="M9 15l4 4 8-8" stroke="#F74C09" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
          `;
        } else if (step === stepNumber) {
          item.classList.add('active');
          // Show number for active step
          svg.innerHTML = `
            <circle cx="15" cy="15" r="15" fill="#F74C09"/>
            <text x="15" y="15" text-anchor="middle" dominant-baseline="middle" fill="white" font-size="14" font-weight="400">${step}</text>
          `;
        } else {
          item.classList.add('inactive');
          // Show grayed out number for inactive steps
          svg.innerHTML = `
            <circle cx="15" cy="15" r="14.5" fill="transparent" stroke="#CCCCCC" stroke-width="2"/>
            <text x="15" y="15" text-anchor="middle" dominant-baseline="middle" fill="#999999" font-size="14" font-weight="400">${step}</text>
          `;
        }
      });
      
      // Update arrows
      const arrows = desktopSteps.querySelectorAll('.step-arrow');
      arrows.forEach((arrow, index) => {
        if (index < stepNumber - 1) {
          arrow.classList.add('active');
        } else {
          arrow.classList.remove('active');
        }
      });
    }
    
    // Update MOBILE steps - rebuild the mobile steps section
    const mobileSteps = stepsBlock.querySelector('.uniforms-hero__steps--mobile');
    if (mobileSteps) {
      let mobileStart = stepNumber;
      if (stepNumber > 3) {
        mobileStart = stepNumber - 1;
      }
      let mobileEnd = mobileStart + 2;
      if (mobileEnd > 5) {
        mobileEnd = 5;
        mobileStart = 3;
      }
      
      const stepLabels = ['Select category', 'Select uniform type', 'Upload designs', 'Sizes & quantity', 'Place order'];
      let mobileHTML = '';
      
      for (let i = mobileStart; i <= mobileEnd; i++) {
        const isPassed = i < stepNumber;
        const isActive = i === stepNumber;
        const isInactive = i > stepNumber;
        
        let svgContent = '';
        if (isPassed) {
          // Show checkmark for passed steps
          svgContent = `
            <circle cx="15" cy="15" r="14.5" fill="transparent" stroke="#F74C09"/>
            <path d="M9 15l4 4 8-8" stroke="#F74C09" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>`;
        } else if (isActive) {
          // Show filled circle with white number for active step
          svgContent = `
            <circle cx="15" cy="15" r="15" fill="#F74C09"/>
            <text x="15" y="15" text-anchor="middle" dominant-baseline="middle" fill="white" font-size="14" font-weight="400">${i}</text>`;
        } else {
          // Show gray circle with gray number for inactive steps
          svgContent = `
            <circle cx="15" cy="15" r="14.5" fill="white" stroke="#999999"/>
            <text x="15" y="15" text-anchor="middle" dominant-baseline="middle" fill="#999999" font-size="14" font-weight="400">${i}</text>`;
        }
        
        const itemClass = isPassed ? 'passed' : (isActive ? 'active' : 'inactive');
        
        mobileHTML += `
          <div class="step-item ${itemClass}">
            <div class="step-circle-wrapper">
              <svg class="step-number" xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 30 30" fill="none">
                ${svgContent}
              </svg>
            </div>
            <div class="step-label">${stepLabels[i-1]}</div>
          </div>`;
        
        if (i < mobileEnd) {
          const arrowActive = i < stepNumber;
          mobileHTML += `
            <div class="step-arrow ${arrowActive ? 'active' : ''}">
              <svg xmlns="http://www.w3.org/2000/svg" width="75" height="6" viewBox="0 0 75 6" fill="none">
                <path d="M75 2.88672L70 -3.26633e-05V5.77347L75 2.88672ZM0 2.88672V3.38672H70.5V2.88672V2.38672H0V2.88672Z" fill="currentColor"/>
              </svg>
            </div>`;
        }
      }
      
      mobileSteps.innerHTML = mobileHTML;
    }
    
    // Show/hide content based on step
    const uploadSection = stepsBlock.querySelector('[data-step-content="3"]');
    const formSection = stepsBlock.querySelector('[data-step-content="4"]');
    
    if (stepNumber === 3) {
      if (uploadSection) uploadSection.style.display = 'block';
      if (formSection) formSection.style.display = 'none';
    } else if (stepNumber === 4) {
      if (uploadSection) uploadSection.style.display = 'none';
      if (formSection) formSection.style.display = 'block';
      
      // Scroll to the form
      if (formSection) {
        formSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    }
  }
  
  // Initialize on page load
  document.addEventListener('DOMContentLoaded', function() {
    // Start at step 3 by default
    goToStep(3);
  });
</script>


<style>
  .product-uniform-steps-block {
    width: 100%;
    padding: 2rem 0;
    margin-bottom: 2rem;
  }

  .product-uniform-steps-block .uniforms-hero__steps {
    display: flex;
    align-items: flex-start;
    gap: 0;
    flex-shrink: 0;
    margin-bottom: 50px;
  }

  .product-uniform-steps-block .step-item {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    position: relative;
  }

  .product-uniform-steps-block .step-circle-wrapper {
    display: block;
    line-height: 0;
    font-size: 0;
  }

  .product-uniform-steps-block .step-number {
    display: block;
    vertical-align: top;
  }

  .product-uniform-steps-block .step-label {
    font-size: 1.1rem;
    color: #999999;
    text-align: left;
    white-space: nowrap;
    font-weight: 500;
    margin-top: 0.5rem;
    position: absolute;
    top: 35px;
    left: 0;
  }

  .product-uniform-steps-block .step-item.active .step-label {
    color: #FF6B35;
  }

  .product-uniform-steps-block .step-item.passed .step-label {
    color: #FF6B35;
  }

  .product-uniform-steps-block .step-arrow {
    color: #CCCCCC;
    margin: 0 1rem 0 0;
    padding: 0;
    display: inline-flex;
    align-items: center;
    line-height: 0;
    height: 30px;
  }

  .product-uniform-steps-block .step-arrow.active {
    color: #FF6B35;
  }

  .product-uniform-steps-block .step-arrow svg {
    display: block;
  }

  .product-uniform-steps-block .uniforms-hero__steps--mobile {
    display: none;
  }

  @media (max-width: 768px) {
    .product-uniform-steps-block {
      padding: 1.5rem 0;
    }

    .product-uniform-steps-block .uniforms-hero__steps--desktop {
      display: none;
    }

    .product-uniform-steps-block .uniforms-hero__steps--mobile {
      display: flex;
      justify-content: center;
      align-items: flex-start;
      gap: 0;
      padding: 0;
      margin-bottom: 50px;
    }

    .product-uniform-steps-block .step-label {
      font-size: 0.875rem;
    }

    .product-uniform-steps-block .step-arrow {
      margin: 0 2rem 0 0;
    }
  }
  /* Navigation Buttons */
  .uniform-step-navigation {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 1rem;
    margin-top: 2rem;
  }

  .uniform-nav-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 2rem;
    border-radius: 50px;
    font-family: 'DM Sans', sans-serif;
    font-size: 16px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    cursor: pointer;
    transition: all 0.3s ease;
    border: none;
    white-space: nowrap;
  }

  .uniform-nav-btn--back {
    background: transparent;
    color: #156571;
    border: 2px solid transparent;
  }

  .uniform-nav-btn--back:hover {
    color: #0C4149;
  }

  .uniform-nav-btn--back svg {
    width: 14px;
    height: 10px;
  }

  .uniform-nav-btn--next {
    background: #F74C09;
    color: white;
    box-shadow: 0 4px 12px rgba(247, 76, 9, 0.3);
  }

  .uniform-nav-btn--next:hover {
    background: #d63d00;
    box-shadow: 0 6px 16px rgba(247, 76, 9, 0.4);
    transform: translateY(-2px);
  }

  .uniform-nav-btn--next svg {
    width: 14px;
    height: 10px;
  }

  @media (max-width: 768px) {
    .uniform-step-navigation {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 0.75rem;
    }

